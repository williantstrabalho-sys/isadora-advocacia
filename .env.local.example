# Supabase — copie para .env.local e preencha com as credenciais do seu projeto
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# Usada apenas em scripts de seed / rotas server-side privilegiadas. NUNCA exponha no client.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# URL pública do site (usada em metadados/SEO)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
